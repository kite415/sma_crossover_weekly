# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token)
DISCORD_TOKEN=

# Your server's ID (right-click the server icon -> Copy Server ID;
# requires Developer Mode: User Settings -> Advanced -> Developer Mode)
GUILD_ID=

# The channel alerts post to (right-click the channel -> Copy Channel ID)
ALERT_CHANNEL_ID=

# live  = evaluate the in-progress weekly/monthly bar (alerts tagged "(tentative)")
# close = act only on completed weekly/monthly bars
CONFIRM_MODE=live

# Daily scan time in America/New_York (default 17:30, Mon-Fri)
SCAN_HOUR=17
SCAN_MINUTE=30
